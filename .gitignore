# Node artifact files
node_modules/
dist/

# Compiled Java class files
*.class

# Compiled Python bytecode
*.py[cod]

# Log files
*.log

# Package files
*.jar

# Maven
target/
dist/

# JetBrains IDE
.idea/

# Unit test reports
TEST*.xml

# Generated by MacOS
.DS_Store

# Generated by Windows
Thumbs.db

# Applications
*.app
*.exe
*.war

# Large media files
*.mp4
*.tiff
*.avi
*.flv
*.mov
*.wmv

# iac
.terraform*
*.auto.tfvars

# secrets
.env
.env.local
.env.bak
secrets/
secret.yaml
credentials.pkr*
*.passwd

# cloudflare tunnel credentials
*.pem
52e4095b-af3c-4c83-9093-328a4845d5ba.json
0088802d-70fc-4b7b-bbdf-11991788c7ca.json


# docker
emqx/

# temp
tmp/
iac/packer
iac/terraform

# python env
venv/

# runtime data
runtime/
logs/